# Copy this file to .env and fill in your values

# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_USE_GOOGLE_SEARCH=true
GEMINI_REQUIRE_SOURCE=true
GEMINI_MIN_CONFIDENCE=0.75

# Public URL the app is served on (used for CORS and the Traefik router host).
CORS_ORIGINS=https://your-app.example.com
BOOK_DOMAIN=your-app.example.com

# --- Cloudflare Access (Zero Trust) -----------------------------------------
# The backend rejects any /api/* request without a valid Access JWT whose
# `aud` matches CF_ACCESS_AUD. Leave both blank to disable auth (local dev).
#
# CF_ACCESS_AUD:         Application Audience (AUD) tag — Cloudflare dashboard
#                        > Zero Trust > Access > Applications > (your app)
#                        > Overview > "Application Audience (AUD) Tag".
# CF_ACCESS_TEAM_DOMAIN: your team domain, e.g. myteam.cloudflareaccess.com
CF_ACCESS_AUD=
CF_ACCESS_TEAM_DOMAIN=
